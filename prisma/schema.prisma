generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? @db.Text
    access_token             String? @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? @db.Text
    session_state            String?
    refresh_token_expires_in Int?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    passwordHash  String?
    accounts      Account[]
    sessions      Session[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─── Photography Domain ──────────────────────────────────────────────────────

model Collection {
    id           String   @id @default(cuid())
    title        String
    description  String?
    coverUrl     String?
    logoUrl      String?
    bannerUrl    String?
    bannerFocalY Float?   @default(0.5)
    slug         String   @unique
    eventDate    DateTime?
    pricePerBib  Decimal  @default(0) @db.Decimal(10, 2)
    isPublished  Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    photos      Photo[]
    purchases   Purchase[]
    faceRecords FaceRecord[]

    @@index([slug])
    @@index([isPublished])
}

// Photos belong directly to a Collection; bibNumber is OCR-detected
model Photo {
    id           String    @id @default(cuid())
    collectionId String
    bibNumber    String?   // OCR-detected bib (null = not yet read or unknown)
    storageKey   String
    filename     String
    fileSize     Int?
    width        Int?
    height       Int?
    order        Int       @default(0)
    previewKey   String?   // Watermarked version key
    createdAt    DateTime  @default(now())

    collection  Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
    faceRecords FaceRecord[]

    @@index([collectionId])
    @@index([collectionId, bibNumber])
}

// Purchase = buying all photos for a bib in a collection
model Purchase {
    id                      String         @id @default(cuid())
    collectionId            String
    bibNumber               String?        // Which bib was purchased
    buyerEmail              String
    buyerName               String?
    buyerLastName           String?
    buyerPhone              String?
    amountPaid              Decimal        @db.Decimal(10, 2)
    currency                String         @default("ARS")
    status                  PurchaseStatus @default(PENDING)
    mercadopagoPreferenceId String?
    mercadopagoPaymentId    String?
    mercadopagoOrderId      String?
    downloadToken           String?        @unique
    downloadTokenExpires    DateTime?
    isPublic                Boolean        @default(false)
    createdAt               DateTime       @default(now())
    updatedAt               DateTime       @updatedAt

    collection Collection @relation(fields: [collectionId], references: [id])

    @@index([collectionId])
    @@index([bibNumber])
    @@index([buyerEmail])
    @@index([downloadToken])
}

enum PurchaseStatus {
    PENDING
    APPROVED
    REJECTED
    REFUNDED
}

// Each face detected & indexed in Rekognition — one row per AWS FaceId
model FaceRecord {
    id           String     @id @default(cuid())
    rekFaceId    String     @unique   // AWS Rekognition FaceId
    photoId      String
    collectionId String
    confidence   Float?               // Rekognition indexing confidence (0-100)
    createdAt    DateTime   @default(now())

    photo      Photo      @relation(fields: [photoId], references: [id], onDelete: Cascade)
    collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

    @@index([collectionId])
    @@index([photoId])
}

model SearchLog {
    id           String   @id @default(cuid())
    collectionId String?
    type         String   // "bib" | "face"
    createdAt    DateTime @default(now())

    @@index([collectionId])
    @@index([createdAt])
}

// ─── Platform Settings ───────────────────────────────────────────────────────

model Setting {
    key       String   @id
    value     String   @db.Text
    updatedAt DateTime @updatedAt
}
